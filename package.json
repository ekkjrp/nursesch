{
  "name": "nursesch",
  "version": "1.0.0",
  "private": true,
  "description": "간호사 근무표 자동 생성 웹서비스",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend_py && C:/ProgramData/Anaconda3/python.exe -m uvicorn app.main:app --reload --port 3000",
    "dev:frontend": "npm run dev --workspace=frontend",
    "seed": "cd backend_py && C:/ProgramData/Anaconda3/python.exe seed.py",
    "test": "npm run test --workspace=frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
