generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Ward {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nurses    Nurse[]
  rule      Rule?
  schedules Schedule[]
  holidays  Holiday[]
}

model Nurse {
  id           Int      @id @default(autoincrement())
  wardId       Int
  name         String
  email        String   @unique
  role         String   @default("NURSE") // ADMIN | NURSE
  skillLevel   String   @default("SENIOR") // JUNIOR | SENIOR | CHARGE
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ward           Ward            @relation(fields: [wardId], references: [id], onDelete: Cascade)
  scheduleEntries ScheduleEntry[]
  shiftRequests  ShiftRequest[]
}

model Rule {
  id                       Int     @id @default(autoincrement())
  wardId                   Int     @unique
  maxConsecutiveWorkDays   Int     @default(5)
  maxConsecutiveNightShifts Int    @default(3)
  minMonthlyOffDays        Int     @default(8)
  weekdayDayCount          Int     @default(3)
  weekdayEveningCount      Int     @default(2)
  weekdayNightCount        Int     @default(2)
  weekendDayCount          Int     @default(2)
  weekendEveningCount      Int     @default(2)
  weekendNightCount        Int     @default(2)
  allowNightToDay          Boolean @default(false)
  allowNightToEvening      Boolean @default(false)
  allowNightOffDay         Boolean @default(false)
  // 제약 조건별 가중치 (JSON)
  constraintWeights        String  @default("{}")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  ward Ward @relation(fields: [wardId], references: [id], onDelete: Cascade)
}

model Schedule {
  id        Int      @id @default(autoincrement())
  wardId    Int
  yearMonth String   // "YYYY-MM" 형식
  status    String   @default("DRAFT") // DRAFT | CONFIRMED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ward    Ward            @relation(fields: [wardId], references: [id], onDelete: Cascade)
  entries ScheduleEntry[]
  shiftRequests ShiftRequest[]
}

model ScheduleEntry {
  id              Int      @id @default(autoincrement())
  scheduleId      Int
  nurseId         Int
  date            String   // "YYYY-MM-DD" 형식
  shiftType       String   // D | E | N | O | X
  isManuallyEdited Boolean @default(false)

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  nurse    Nurse    @relation(fields: [nurseId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, nurseId, date])
}

model ShiftRequest {
  id                 Int      @id @default(autoincrement())
  nurseId            Int
  scheduleId         Int
  date               String   // "YYYY-MM-DD" 형식
  requestedShiftType String   // D | E | N | O | X
  status             String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reason             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  nurse    Nurse    @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

model Holiday {
  id     Int    @id @default(autoincrement())
  wardId Int
  date   String // "YYYY-MM-DD" 형식
  name   String
  type   String @default("HOLIDAY") // HOLIDAY | EDUCATION | OTHER

  ward Ward @relation(fields: [wardId], references: [id], onDelete: Cascade)

  @@unique([wardId, date])
}
